---
import BaseLayout from '../../layouts/BaseLayout.astro';
import products from '../../data/products.json';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const categories = [...new Set(products.map(p => p.category))];
const brands = [...new Set(products.map(p => p.brand))];
const productsJson = products.map(p => ({ id: p.id, name: p.name, brand: p.brand, category: p.category, price: p.price }));
---

<BaseLayout title="全部商品">
  <div class="container">
    <div class="products-header">
      <h1 class="page-title">全部商品</h1>
      <span class="product-count" id="productCount">顯示 0 / {products.length} 件</span>
    </div>

    <div class="filters">
      <div class="filter-group">
        <label>分類</label>
        <select id="categoryFilter">
          <option value="">全部分類</option>
          {categories.map(cat => <option value={cat}>{cat}</option>)}
        </select>
      </div>
      <div class="filter-group">
        <label>品牌</label>
        <select id="brandFilter">
          <option value="">全部品牌</option>
          {brands.map(b => <option value={b}>{b}</option>)}
        </select>
      </div>
      <div class="filter-group">
        <label>排序</label>
        <select id="sortFilter">
          <option value="default">預設</option>
          <option value="price-asc">價格由低到高</option>
          <option value="price-desc">價格由高到低</option>
          <option value="name">名稱 A-Z</option>
        </select>
      </div>
    </div>

    <div class="products-grid" id="productsGrid">
      {products.map(product => (
        <a href={`${base}products/${product.id}/`} class="product-card ga4-product-card"
           data-category={product.category} data-brand={product.brand}
           data-price={product.price} data-name={product.name}
           data-product-id={product.id} data-product-category={product.category}
           data-product-brand={product.brand} data-product-price={product.price}>
          <div class="product-img">
            <img src={product.image} alt={product.name} loading="lazy" />
            <span class="badge product-badge">{product.badge}</span>
          </div>
          <div class="product-info">
            <div class="product-title">
              <span>{product.name}</span>
              <span class="product-brand">{product.brand}</span>
            </div>
            <p class="product-desc">{product.desc}</p>
            <div class="product-footer">
              <span class="price">${product.price} <small>USD</small></span>
              <span class="btn btn-primary btn-sm">查看詳情</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <p class="no-results" id="noResults" style="display:none;">沒有找到符合條件的商品</p>
    <div class="load-more-wrap" id="loadMoreWrap" style="display:none;">
      <button class="btn btn-secondary btn-lg" id="loadMoreBtn"><i class="fas fa-plus"></i> 載入更多商品</button>
    </div>
  </div>
</BaseLayout>

<style>
  .products-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1rem; }
  .page-title { font-size: 2rem; font-weight: 800; margin-bottom: 0; }
  .product-count { font-size: 0.85rem; color: var(--color-text-muted); font-weight: 500; }

  .filters {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .filter-group { display: flex; flex-direction: column; gap: 0.25rem; }
  .filter-group label { font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); }
  .filter-group select {
    padding: 0.6rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: white;
    font-size: 0.85rem;
    cursor: pointer;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .product-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border-light);
    transition: all 0.3s cubic-bezier(0.2, 0, 0, 1);
  }
  .product-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-accent);
    background: var(--color-surface-solid);
  }
  .product-card.hidden { display: none; }
  .product-card.load-hidden { display: none; }

  .product-img { position: relative; background: var(--color-bg); }
  .product-img img { width: 100%; height: 200px; object-fit: cover; }
  .product-badge { position: absolute; top: 0.75rem; left: 0.75rem; }

  .product-info { padding: 1.25rem 1.5rem 1.5rem; }
  .product-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
    font-size: 1.1rem;
    font-weight: 700;
  }
  .product-brand { font-size: 0.75rem; color: var(--color-text-muted); font-weight: 500; }
  .product-desc {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .product-footer { display: flex; align-items: center; justify-content: space-between; }
  .price { font-size: 1.4rem; font-weight: 800; color: var(--color-accent); }
  .price small { font-size: 0.75rem; font-weight: 500; color: var(--color-text-muted); }
  .btn-sm { padding: 0.5rem 1rem; font-size: 0.8rem; }

  .no-results { text-align: center; padding: 3rem; color: var(--color-text-muted); font-size: 1.1rem; }
  .load-more-wrap { text-align: center; padding: 2rem 0; }
  .btn-lg { padding: 0.85rem 2rem; font-size: 0.95rem; }

  @media (max-width: 768px) {
    .products-header { flex-direction: column; gap: 0.25rem; }
    .products-grid { grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); }
  }
</style>

<script define:vars={{ products, productsJson }}>
  var PAGE_SIZE = 12;
  var visibleCount = PAGE_SIZE;
  var allVisibleCards = [];

  const params = new URLSearchParams(window.location.search);
  const cards = document.querySelectorAll('.product-card');

  // GA4: view_item_list
  if (typeof GA4 !== 'undefined') {
    GA4.viewItemList(productsJson, 'all-products', '全部商品列表');
  }

  // GA4: select_item
  document.querySelectorAll('.ga4-product-card').forEach(function (card) {
    card.addEventListener('click', function () {
      if (typeof GA4 === 'undefined') return;
      var item = {
        id: parseInt(card.dataset.productId),
        name: card.dataset.productName || card.dataset.name,
        brand: card.dataset.productBrand || card.dataset.brand,
        category: card.dataset.productCategory || card.dataset.category,
        price: parseFloat(card.dataset.productPrice || card.dataset.price)
      };
      GA4.selectItem(item, 'all-products', '全部商品列表');
    });
  });

  // Handle search
  if (params.get('search')) {
    var term = params.get('search').toLowerCase();
    cards.forEach(function (card) {
      var n = (card.dataset.name || '').toLowerCase();
      var b = (card.dataset.brand || '').toLowerCase();
      var c = (card.dataset.category || '').toLowerCase();
      if (!n.includes(term) && !b.includes(term) && !c.includes(term)) {
        card.classList.add('hidden');
      }
    });
  }

  function updateLoadMore() {
    var countEl = document.getElementById('productCount');
    var wrap = document.getElementById('loadMoreWrap');
    var btn = document.getElementById('loadMoreBtn');
    var total = allVisibleCards.length;
    var showing = Math.min(visibleCount, total);

    if (countEl) countEl.textContent = '顯示 ' + showing + ' / ' + total + ' 件';

    // Show/hide based on load-hidden
    allVisibleCards.forEach(function (card, i) {
      if (i < visibleCount) {
        card.classList.remove('load-hidden');
      } else {
        card.classList.add('load-hidden');
      }
    });

    if (wrap) wrap.style.display = showing < total ? 'block' : 'none';
  }

  document.getElementById('loadMoreBtn')?.addEventListener('click', function () {
    visibleCount += PAGE_SIZE;
    updateLoadMore();
  });

  function applyFilters() {
    var category = document.getElementById('categoryFilter')?.value || params.get('category') || '';
    var brand = document.getElementById('brandFilter')?.value || params.get('brand') || '';
    var sort = document.getElementById('sortFilter')?.value || 'default';

    var grid = document.getElementById('productsGrid');

    var sortedCards = [...cards];
    if (sort === 'price-asc') sortedCards.sort(function (a, b) { return +a.dataset.price - +b.dataset.price; });
    else if (sort === 'price-desc') sortedCards.sort(function (a, b) { return +b.dataset.price - +a.dataset.price; });
    else if (sort === 'name') sortedCards.sort(function (a, b) { return a.dataset.name.localeCompare(b.dataset.name); });

    allVisibleCards = [];
    sortedCards.forEach(function (card) {
      var matchCat = !category || card.dataset.category === category;
      var matchBrand = !brand || card.dataset.brand === brand;
      if (matchCat && matchBrand) {
        card.classList.remove('hidden');
        allVisibleCards.push(card);
      } else {
        card.classList.add('hidden');
        card.classList.add('load-hidden');
      }
    });

    sortedCards.forEach(function (card) { grid?.appendChild(card); });

    var noResults = document.getElementById('noResults');
    if (noResults) noResults.style.display = allVisibleCards.length === 0 ? 'block' : 'none';

    visibleCount = PAGE_SIZE;
    updateLoadMore();
  }

  if (params.get('category')) {
    var catEl = document.getElementById('categoryFilter');
    if (catEl) catEl.value = params.get('category');
  }
  if (params.get('brand')) {
    var brandEl = document.getElementById('brandFilter');
    if (brandEl) brandEl.value = params.get('brand');
  }

  applyFilters();

  // GA4: filter_applied + sort_applied
  document.getElementById('categoryFilter')?.addEventListener('change', function () {
    applyFilters();
    if (typeof GA4 !== 'undefined' && this.value) {
      GA4.filterApplied('category', this.value);
    }
  });
  document.getElementById('brandFilter')?.addEventListener('change', function () {
    applyFilters();
    if (typeof GA4 !== 'undefined' && this.value) {
      GA4.filterApplied('brand', this.value);
    }
  });
  document.getElementById('sortFilter')?.addEventListener('change', function () {
    applyFilters();
    if (typeof GA4 !== 'undefined' && this.value !== 'default') {
      GA4.sortApplied(this.value);
    }
  });
</script>
